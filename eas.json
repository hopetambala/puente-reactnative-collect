{
  "cli": {
    "version": ">= 2.3.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "environment": "development",
      "node": "20.19.6"
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "environment": "preview",
      "node": "20.19.6"
    },
    "production": {
      "ios": {
        "image": "latest"
      },
      "android": {
        "gradleCommand": ":app:bundleRelease",
        "cache": {
          "disabled": false
        }
      },
      "channel": "production",
      "environment": "production",
      "node": "20.19.6",
      "env": {
        "GOOGLE_MAPS_API_KEY": "@GOOGLE_MAPS_API_KEY"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
