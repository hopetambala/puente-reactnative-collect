{
  "name": "puente-reactnative",
  "version": "14.0.3",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "start-clear": "expo start --clear",
    "start:staging": "cross-env APP_ENV=staging EXPO_PUBLIC_APP_ENV=staging expo start",
    "start:staging-clear": "cross-env APP_ENV=staging EXPO_PUBLIC_APP_ENV=staging expo start --clear",
    "start:prod": "cross-env APP_ENV=prod EXPO_PUBLIC_APP_ENV=prod expo start",
    "start:prod-clear": "cross-env APP_ENV=prod EXPO_PUBLIC_APP_ENV=prod expo start --clear",
    "reinstall": "rm yarn.lock && rm -rf node_modules/ && yarn install",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "eject": "expo eject",
    "test": "jest --watchAll",
    "test-debug": "jest -o --watch --coverage=false",
    "test-run": "jest --forceExit --detectOpenHandles",
    "lint": "eslint '**/*.{js,jsx}' --quiet",
    "lint-fix": "eslint '**/*.{js,jsx}' --fix",
    "prettier": "prettier --write '**/*.{js,jsx}'",
    "build-apps": "cross-env APP_ENV=prod EXPO_PUBLIC_APP_ENV=prod eas build --platform all",
    "submit-apps": "eas submit -p ios --latest && eas submit -p android --latest",
    "gh-prune": "git fetch -p && for branch in `git branch -vv | grep ': gone]' | awk '{print $1}'`; do git branch -D $branch; done",
    "release-patch": "standard-version --release-as patch",
    "release-minor": "standard-version --release-as minor",
    "release-major": "standard-version --release-as major",
    "postinstall": "patch-package",
    "post-version": "node scripts/update-version/versionNumber.js"
  },
  "jest": {
    "preset": "jest-expo",
    "collectCoverage": true,
    "collectCoverageFrom": [
      "**/*.{js,jsx}",
      "!**/coverage/**",
      "!**/node_modules/**",
      "!**/babel.config.js",
      "!**/jest.setup.js"
    ],
    "moduleNameMapper": {
      "^parse/react-native$": "parse/node"
    }
  },
  "dependencies": {
    "@expo/config-plugins": "~55.0.6",
    "@expo/metro-config": "~55.0.9",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.5.2",
    "@react-native-masked-view/masked-view": "0.3.2",
    "@react-native-picker/picker": "2.11.4",
    "@react-navigation/bottom-tabs": "^7.5.2",
    "@react-navigation/native": "^7.1.18",
    "@react-navigation/native-stack": "^7.3.26",
    "axios": "^1.7.9",
    "deprecated-react-native-prop-types": "^5.0.0",
    "expo": "~55.0.5",
    "expo-application": "~55.0.10",
    "expo-asset": "~55.0.10",
    "expo-build-properties": "~55.0.10",
    "expo-camera": "~55.0.10",
    "expo-constants": "~55.0.9",
    "expo-font": "~55.0.4",
    "expo-glass-effect": "~55.0.8",
    "expo-image-picker": "~55.0.13",
    "expo-linking": "~55.0.8",
    "expo-localization": "~55.0.9",
    "expo-location": "~55.1.4",
    "expo-mail-composer": "~55.0.9",
    "expo-network": "~55.0.9",
    "expo-notifications": "~55.0.13",
    "expo-splash-screen": "~55.0.12",
    "expo-store-review": "~55.0.9",
    "expo-updates": "~55.0.15",
    "expo-web-browser": "~55.0.10",
    "formik": "^2.4.6",
    "i18n-js": "^4.4.3",
    "lodash": "^4.17.21",
    "metro-react-native-babel-transformer": "^0.77.0",
    "parse": "2.19.0",
    "patch-package": "^8.0.0",
    "prop-types": "^15.8.1",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-autocomplete-input": "^5.4.0",
    "react-native-emoji": "1.8.0",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-get-random-values": "~1.11.0",
    "react-native-localize": "^3.2.1",
    "react-native-maps": "1.27.2",
    "react-native-pager-view": "8.0.0",
    "react-native-paper": "^5.12.5",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-svg-transformer": "^1.5.0",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-uuid": "^2.0.2",
    "react-native-worklets": "0.7.2",
    "style-dictionary-dlite-tokens": "^0.2.7",
    "yup": "^1.4.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@babel/eslint-parser": "^7.28.5",
    "@babel/preset-react": "^7.28.5",
    "@faker-js/faker": "^9.3.0",
    "babel-eslint": "10.1.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-preset-expo": "~55.0.0",
    "cross-env": "^10.1.0",
    "deep-merge": "1.0.0",
    "env-cmd": "^10.1.0",
    "eslint": "^8.57.1",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-babel-module": "^5.3.2",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-module-resolver": "^1.5.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-native": "^4.1.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "jest": "^29.0.0",
    "jest-expo": "~55.0.11",
    "prettier": "^3.4.2",
    "prompt": "^1.3.0",
    "standard-version": "^9.5.0",
    "standard-version-expo": "^1.0.3"
  },
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "yarn": ">=1.22.0"
  }
}
